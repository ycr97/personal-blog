* text=auto eol=lf
*.age binary

# Preserve Markdown hard-break spaces in the reviewed, byte-identical article.
src/content/posts/factory-pattern-in-practice.md whitespace=-trailing-space

# Preserve whitespace from the authenticated CSDN Markdown sources.
# Current CSDN article IDs contain eight or nine digits and form the filename suffix.
src/content/posts/*-????????.md whitespace=-trailing-space,-space-before-tab
src/content/posts/*-?????????.md whitespace=-trailing-space,-space-before-tab
